        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.name as player_name,\n  TRIM(BOTH '\"' FROM g.game_type) as game_type,\n  SUM(\n    COALESCE(\n      (SELECT SUM(s::int) FROM jsonb_array_elements_text(p.scores) AS s),\n      0\n    )\n  )::bigint as total_score\nFROM players p\nJOIN games g ON p.game_id = g.id\nGROUP BY p.name, g.game_type\nORDER BY total_score DESC\nLIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Top Scores by Game Type",
