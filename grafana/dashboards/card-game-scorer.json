          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.name as player_name,\n  ROUND(AVG(\n    COALESCE(\n      (SELECT SUM(s::int) FROM jsonb_array_elements_text(p.scores) AS s),\n      0\n    )\n  ), 1) as avg_score,\n  COUNT(*)::bigint as games_played\nFROM players p\nGROUP BY p.name\nHAVING COUNT(*) >= 3\nORDER BY avg_score DESC\nLIMIT 15",
          "refId": "A"
        }
      ],
